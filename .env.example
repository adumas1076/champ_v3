# ============================================
# CHAMP V3 — Environment Variables
# Copy to .env and fill in real values
# ============================================

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=sk-litellm-xxxxxxxxxxxxxxxxxxxxx
LITELLM_BASE_URL=http://127.0.0.1:4001/v1

# --- Brain Server ---
BRAIN_HOST=0.0.0.0
BRAIN_PORT=8100
BRAIN_URL=http://127.0.0.1:8100

# --- LiveKit (Voice) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ElevenLabs (TTS) ---
ELEVEN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (Memory) ---
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Ears (Local Only — not deployed) ---
EARS_HEALTH_URL=http://127.0.0.1:8101/health
EARS_ROOM_NAME=champ-ears
WAKE_THRESHOLD=0.5
WAKE_VAD_THRESHOLD=0.5
AUDIO_DEVICE_INDEX=
EARS_SILENCE_TIMEOUT=30.0
EARS_COOLDOWN=2.0

# --- Logging ---
CHAMP_LOG_LEVEL=DEBUG
